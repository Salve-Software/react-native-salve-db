{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "salvedb"
  ],
  "ios": {
    "iosModuleName": "SalveDb"
  },
  "android": {
    "androidNamespace": [
      "salvedb"
    ],
    "androidCxxLibName": "SalveDb"
  },
  "autolinking": {
    "SalveDb": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridSalveDb"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}