{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "salvedb"
  ],
  "ios": {
    "iosModuleName": "NitroSalveDb"
  },
  "android": {
    "androidNamespace": [
      "salvedb"
    ],
    "androidCxxLibName": "NitroSalveDb"
  },
  "autolinking": {
    "DatabaseBridge": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridDatabaseBridge"
      }
    },
    "QueryBridge": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridQueryBridge"
      }
    },
    "SyncBridge": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridSyncBridge"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
